{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "goodblocks/testimonials",
  "title": "Testimonials",
  "category": "goodblocks",
  "icon": "format-quote",
  "description": "A carousel of quotes with author and role.",
  "keywords": [
    "testimonials",
    "quotes",
    "carousel",
    "reviews"
  ],
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "padding": true,
      "margin": true
    }
  },
  "attributes": {
    "items": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "properties": {
          "quote": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      }
    },
    "autoplay": {
      "type": "boolean",
      "default": true
    },
    "autoplayDelay": {
      "type": "number",
      "default": 5000
    },
    "animation": {
      "type": "string",
      "default": "fade",
      "enum": [
        "fade",
        "slide"
      ]
    },
    "showArrows": {
      "type": "boolean",
      "default": true
    },
    "showDots": {
      "type": "boolean",
      "default": true
    }
  },
  "example": {
    "attributes": {
      "items": [
        {
          "quote": "An outstanding experience from start to finish.",
          "author": "Anna Svensson",
          "role": "CEO, Acme AB"
        }
      ]
    }
  },
  "textdomain": "goodblocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "viewStyle": "file:./view.css",
  "render": "file:./render.php"
}